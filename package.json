{
  "name": "nclient-desktop",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron": "electron .",
    "start": "concurrently -k -p \"[{name}]\" -n \"Vite,Electron\" -c \"cyan,green\" \"npm run dev\" \"node start-electron.cjs\"",
    "package": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "lucide-react": "^0.435.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "electron": "^31.0.0",
    "concurrently": "^8.2.2",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.maxwai.nclientdesktop",
    "productName": "NClientDesktop",
    "icon": "icon.png",
    "directories": {
      "output": "dist-build"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "electron-preload.js",
      "doh-client.cjs",
      "package.json",
      "icon.png",
      "icon.ico"
    ],
    "win": {
      "icon": "icon.ico",
      "target": "portable"
    }
  }
}
